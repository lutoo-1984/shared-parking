<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 位置权限 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- 存储权限（用于图片上传） -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- 相机权限（用于扫码支付） -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- 网络配置 -->
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />
    <uses-feature android:name="android.hardware.location.network" android:required="false" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <application
        android:name=".application.SharedParkingApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SharedParking"
        android:usesCleartextTraffic="true">

        <!-- 启动Activity -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SharedParking.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 测试Activity -->
        <activity
            android:name=".ui.SimpleTestActivity"
            android:exported="false"
            android:theme="@style/Theme.SharedParking" />

        <!-- 主Activity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize" />

        <!-- 认证相关Activity -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 停车位相关Activity -->
        <activity
            android:name=".ui.parking.ParkingSearchActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.parking.ParkingDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.parking.LocationPickerActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 预订相关Activity -->
        <activity
            android:name=".ui.booking.BookingActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.booking.BookingDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 支付相关Activity -->
        <activity
            android:name=".ui.payment.PaymentActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.payment.PaymentDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.payment.PaymentSuccessActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.payment.PaymentHistoryActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 个人中心相关Activity -->
        <activity
            android:name=".ui.parking.MySpotsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.parking.CreateSpotActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.booking.MyBookingsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.messages.MessagesActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.map.MapActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 服务（如果需要后台服务） -->
        <service
            android:name=".service.LocationService"
            android:exported="false" />

        <service
            android:name=".service.NotificationService"
            android:exported="false" />

        <!-- 广播接收器（用于网络状态监听等） -->
        <receiver
            android:name=".receiver.NetworkChangeReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
            </intent-filter>
        </receiver>

        <!-- 文件提供者（用于文件分享）- 暂时注释掉
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        -->

        <!-- 元数据 -->
        <!-- 百度地图API Key - 需要配置
        <meta-data
            android:name="com.baidu.lbsapi.API_KEY"
            android:value="YOUR_BAIDU_MAP_API_KEY" />
        -->

        <!-- 预加载字体 - 暂时注释掉
        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
        -->

    </application>

</manifest>