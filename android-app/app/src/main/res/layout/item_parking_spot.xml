<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/spacing_medium"
    android:layout_marginEnd="@dimen/spacing_medium"
    android:layout_marginBottom="@dimen/spacing_small"
    style="@style/Widget.SharedParking.CardView">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_medium">

        <!-- 停车位图片 -->
        <ImageView
            android:id="@+id/ivSpotImage"
            android:layout_width="100dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_parking_placeholder"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 收藏按钮 -->
        <ImageView
            android:id="@+id/ivFavorite"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_margin="@dimen/spacing_small"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_favorite_border"
            app:layout_constraintEnd_toEndOf="@id/ivSpotImage"
            app:layout_constraintTop_toTopOf="@id/ivSpotImage"
            app:tint="@color/white" />

        <!-- 标题和地址 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_small"
            android:layout_marginEnd="@dimen/spacing_small"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/Text.Title.Medium"
            android:textColor="@color/text_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivSpotImage"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="小区地下停车场B区" />

        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xsmall"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/Text.Body.Small"
            android:textColor="@color/text_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivSpotImage"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            tools:text="北京市朝阳区建国路88号SOHO现代城地下停车场B区" />

        <!-- 价格和距离 -->
        <LinearLayout
            android:id="@+id/layoutPriceDistance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivSpotImage"
            app:layout_constraintTop_toBottomOf="@id/tvAddress">

            <!-- 价格 -->
            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/Text.Title.Medium"
                android:textColor="@color/brand_primary"
                tools:text="¥15/小时" />

            <!-- 距离 -->
            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_small"
                android:textAppearance="@style/Text.Body.Small"
                android:textColor="@color/text_hint"
                tools:text="1.2km" />

        </LinearLayout>

        <!-- 设施标签 -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFacilities"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            app:chipSpacingHorizontal="@dimen/spacing_xsmall"
            app:chipSpacingVertical="@dimen/spacing_xsmall"
            app:singleLine="true"
            app:singleSelection="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivSpotImage"
            app:layout_constraintTop_toBottomOf="@id/layoutPriceDistance">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCovered"
                style="@style/Widget.SharedParking.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="有顶棚"
                android:visibility="gone" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipLighting"
                style="@style/Widget.SharedParking.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="照明"
                android:visibility="gone" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSecurity"
                style="@style/Widget.SharedParking.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="安保"
                android:visibility="gone" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCharging"
                style="@style/Widget.SharedParking.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="充电"
                android:visibility="gone" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip24h"
                style="@style/Widget.SharedParking.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24小时"
                android:visibility="gone" />

        </com.google.android.material.chip.ChipGroup>

        <!-- 评价信息 -->
        <LinearLayout
            android:id="@+id/layoutRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            android:orientation="horizontal"
            app:layout_constraintStart_toEndOf="@id/ivSpotImage"
            app:layout_constraintTop_toBottomOf="@id/chipGroupFacilities">

            <!-- 评分 -->
            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_xsmall"
                android:textAppearance="@style/Text.Body.Small"
                android:textColor="@color/text_hint"
                tools:text="4.8" />

            <!-- 星星图标 -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="@dimen/spacing_xsmall"
                android:src="@drawable/ic_star"
                app:tint="@color/warning" />

            <!-- 评价数量 -->
            <TextView
                android:id="@+id/tvReviewCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Text.Body.Small"
                android:textColor="@color/text_hint"
                tools:text="(128)" />

        </LinearLayout>

        <!-- 状态标签 -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipStatus"
            style="@style/Widget.SharedParking.Chip.Status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/spacing_small"
            android:text="可预订"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/chipGroupFacilities" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>