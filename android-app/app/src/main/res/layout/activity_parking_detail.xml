<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:fitsSystemWindows="true"
            app:contentScrim="?attr/colorPrimary"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:statusBarScrim="@android:color/transparent"
            app:titleEnabled="false"
            app:toolbarId="@+id/toolbar">

            <!-- 图片轮播 -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPager"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fitsSystemWindows="true" />

            <!-- 图片指示器 -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center"
                android:layout_marginBottom="@dimen/spacing_medium"
                app:tabBackground="@drawable/tab_indicator"
                app:tabGravity="center"
                app:tabIndicatorHeight="0dp"
                app:tabRippleColor="@null" />

            <!-- 返回按钮 -->
            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_medium"
                android:layout_marginTop="@dimen/spacing_medium"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/white" />

            <!-- 收藏按钮 -->
            <ImageView
                android:id="@+id/ivFavorite"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="@dimen/spacing_medium"
                android:layout_marginTop="@dimen/spacing_medium"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_favorite_border"
                android:layout_gravity="end"
                app:tint="@color/white" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@android:color/transparent"
                app:layout_collapseMode="pin"
                app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
                app:title="停车位详情" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 内容区域 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/layoutContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- 基本信息卡片 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SharedParking.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/spacing_medium"
                app:cardElevation="@dimen/elevation_small">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_medium">

                    <!-- 标题和价格 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_small">

                        <TextView
                            android:id="@+id/tvTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textAppearance="@style/Text.Title.Large"
                            android:textColor="@color/text_primary"
                            tools:text="小区地下停车场B区" />

                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/Text.Title.Large"
                            android:textColor="@color/brand_primary"
                            tools:text="¥15/小时" />

                    </LinearLayout>

                    <!-- 地址 -->
                    <TextView
                        android:id="@+id/tvAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_medium"
                        android:textAppearance="@style/Text.Body.Medium"
                        android:textColor="@color/text_secondary"
                        tools:text="北京市朝阳区建国路88号SOHO现代城地下停车场B区" />

                    <!-- 设施标签 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:text="设施"
                        android:textAppearance="@style/Text.Title.Small"
                        android:textColor="@color/text_primary" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupFacilities"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="@dimen/spacing_xsmall"
                        app:chipSpacingVertical="@dimen/spacing_xsmall">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCovered"
                            style="@style/Widget.SharedParking.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="有顶棚" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipLighting"
                            style="@style/Widget.SharedParking.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="照明" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSecurity"
                            style="@style/Widget.SharedParking.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="安保" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCharging"
                            style="@style/Widget.SharedParking.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="充电" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip24h"
                            style="@style/Widget.SharedParking.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24小时" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCctv"
                            style="@style/Widget.SharedParking.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="监控" />

                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 详情描述卡片 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SharedParking.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_medium"
                android:layout_marginEnd="@dimen/spacing_medium"
                android:layout_marginBottom="@dimen/spacing_medium"
                app:cardElevation="@dimen/elevation_small">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_medium">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:text="详情描述"
                        android:textAppearance="@style/Text.Title.Small"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/Text.Body.Medium"
                        android:textColor="@color/text_secondary"
                        tools:text="这是一个宽敞的地下停车位，位于小区B区，靠近电梯口，出入方便。车位干净整洁，有专人定期清扫。" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 车位规格卡片 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SharedParking.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_medium"
                android:layout_marginEnd="@dimen/spacing_medium"
                android:layout_marginBottom="@dimen/spacing_medium"
                app:cardElevation="@dimen/elevation_small">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_medium">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:text="车位规格"
                        android:textAppearance="@style/Text.Title.Small"
                        android:textColor="@color/text_primary" />

                    <androidx.gridlayout.widget.GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="3">

                        <!-- 最大高度 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginBottom="@dimen/spacing_small"
                            android:text="最大高度:"
                            android:textAppearance="@style/Text.Body.Medium"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvMaxHeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginBottom="@dimen/spacing_small"
                            android:textAppearance="@style/Text.Body.Medium"
                            android:textColor="@color/text_primary"
                            tools:text="2.2米" />

                        <!-- 最大宽度 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginBottom="@dimen/spacing_small"
                            android:text="最大宽度:"
                            android:textAppearance="@style/Text.Body.Medium"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvMaxWidth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginBottom="@dimen/spacing_small"
                            android:textAppearance="@style/Text.Body.Medium"
                            android:textColor="@color/text_primary"
                            tools:text="2.5米" />

                        <!-- 可用车位 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="可用车位:"
                            android:textAppearance="@style/Text.Body.Medium"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvAvailableSpots"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:textAppearance="@style/Text.Body.Medium"
                            android:textColor="@color/text_primary"
                            tools:text="3/5" />

                    </androidx.gridlayout.widget.GridLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 车主信息卡片 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SharedParking.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_medium"
                android:layout_marginEnd="@dimen/spacing_medium"
                android:layout_marginBottom="@dimen/spacing_medium"
                app:cardElevation="@dimen/elevation_small">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_medium">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:text="车主信息"
                        android:textAppearance="@style/Text.Title.Small"
                        android:textColor="@color/text_primary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- 头像 -->
                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/ivOwnerAvatar"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="@dimen/spacing_small"
                            android:src="@drawable/ic_person"
                            app:civ_border_color="@color/border"
                            app:civ_border_width="1dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- 用户名 -->
                            <TextView
                                android:id="@+id/tvOwnerUsername"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/Text.Title.Small"
                                android:textColor="@color/text_primary"
                                tools:text="张三" />

                            <!-- 评价信息 -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <!-- 评分 -->
                                <TextView
                                    android:id="@+id/tvOwnerRating"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="@dimen/spacing_xsmall"
                                    android:textAppearance="@style/Text.Body.Small"
                                    android:textColor="@color/text_hint"
                                    tools:text="4.8" />

                                <!-- 星星图标 -->
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginEnd="@dimen/spacing_xsmall"
                                    android:src="@drawable/ic_star"
                                    app:tint="@color/warning" />

                                <!-- 评价数量 -->
                                <TextView
                                    android:id="@+id/tvOwnerReviewCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textAppearance="@style/Text.Body.Small"
                                    android:textColor="@color/text_hint"
                                    tools:text="(128条评价)" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- 联系按钮 -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnContactOwner"
                            style="@style/Widget.SharedParking.Button.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/ic_message"
                            android:text="联系" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 加载状态 -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@color/surface">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="加载中..."
            android:textAppearance="@style/Text.Body.Medium"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

    <!-- 错误状态 -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@color/surface"
        android:padding="@dimen/spacing_large">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginBottom="@dimen/spacing_medium"
            android:src="@drawable/ic_info"
            app:tint="@color/error" />

        <TextView
            android:id="@+id/tvErrorMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_medium"
            android:text="加载失败，请重试"
            android:textAppearance="@style/Text.Body.Medium"
            android:textColor="@color/text_secondary"
            android:textAlignment="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            style="@style/Widget.SharedParking.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="重试" />

    </LinearLayout>

    <!-- 底部操作栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/surface"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="@dimen/spacing_medium">

        <!-- 价格信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_small">

            <TextView
                android:id="@+id/tvFinalPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/Text.Title.Large"
                android:textColor="@color/brand_primary"
                tools:text="¥15/小时" />

            <TextView
                android:id="@+id/tvOriginalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:textAppearance="@style/Text.Body.Small.Strikethrough"
                android:textColor="@color/text_hint"
                tools:text="¥20/小时" />

        </LinearLayout>

        <!-- 预订按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBookNow"
            style="@style/Widget.SharedParking.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="立即预订"
            android:textSize="18sp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>