<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="@dimen/spacing_medium">

    <!-- 成功图标 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_check_circle"
            android:tint="@color/brand_success" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            android:text="支付成功！"
            android:textAppearance="@style/Text.Title.Large"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xsmall"
            android:text="订单已确认，可以开始使用车位"
            android:textAppearance="@style/Text.Body.Medium"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- 支付信息卡片 -->
    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.SharedParking.CardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_medium"
        app:cardElevation="@dimen/elevation_small">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_medium">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_medium"
                android:text="支付详情"
                android:textAppearance="@style/Text.Title.Small"
                android:textColor="@color/text_primary" />

            <!-- 支付金额 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_small"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="支付金额"
                    android:textAppearance="@style/Text.Body.Medium"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvPaymentAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¥60.00"
                    android:textAppearance="@style/Text.Title.Medium"
                    android:textColor="@color/brand_primary" />
            </LinearLayout>

            <!-- 支付方式 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_small"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="支付方式"
                    android:textAppearance="@style/Text.Body.Medium"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvPaymentMethod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="支付宝"
                    android:textAppearance="@style/Text.Body.Medium"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- 交易号 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_small"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="交易号"
                    android:textAppearance="@style/Text.Body.Medium"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvTransactionId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="202603221234567890"
                    android:textAppearance="@style/Text.Body.Small"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- 支付时间 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="支付时间"
                    android:textAppearance="@style/Text.Body.Medium"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvPaidTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2026-03-22 14:30:25"
                    android:textAppearance="@style/Text.Body.Small"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewBooking"
            style="@style/Widget.SharedParking.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="@dimen/spacing_small"
            android:text="查看订单详情"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToHome"
            style="@style/Widget.SharedParking.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="返回首页"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>