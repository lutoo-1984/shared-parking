<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_medium">

            <!-- 欢迎语 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_large"
                android:text="@string/app_tagline"
                android:textAlignment="center"
                android:textAppearance="@style/Text.Title.Medium"
                android:textColor="@color/brand_primary" />

            <!-- 快捷操作卡片 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SharedParking.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_large">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_medium"
                        android:text="快捷操作"
                        android:textAppearance="@style/Text.Title.Small" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="4">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSearchParking"
                            style="@style/Widget.SharedParking.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:text="搜索车位" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMapView"
                            style="@style/Widget.SharedParking.Button.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:text="地图" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnViewBookings"
                            style="@style/Widget.SharedParking.Button.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:text="我的预订" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCreateSpot"
                            style="@style/Widget.SharedParking.Button.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="发布车位" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 推荐停车位 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SharedParking.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_large">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_medium"
                        android:text="推荐车位"
                        android:textAppearance="@style/Text.Title.Small" />

                    <!-- 推荐列表 -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecommendations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_parking_spot" />

                    <TextView
                        android:id="@+id/tvEmptyRecommendations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="@dimen/spacing_xlarge"
                        android:text="暂无推荐车位"
                        android:textAppearance="@style/Text.Body.Medium"
                        android:textColor="@color/text_hint"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 最近搜索 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SharedParking.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_medium"
                        android:text="最近搜索"
                        android:textAppearance="@style/Text.Title.Small" />

                    <!-- 最近搜索标签 -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupRecentSearches"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleLine="false"
                        app:singleSelection="false" />

                    <TextView
                        android:id="@+id/tvEmptyRecentSearches"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="@dimen/spacing_large"
                        android:text="暂无搜索记录"
                        android:textAppearance="@style/Text.Body.Medium"
                        android:textColor="@color/text_hint"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>