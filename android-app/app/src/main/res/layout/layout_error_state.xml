<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/spacing_large">

    <ImageView
        android:id="@+id/ivErrorIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:src="@drawable/ic_error"
        android:tint="@color/brand_error"
        tools:src="@drawable/ic_error" />

    <TextView
        android:id="@+id/tvErrorTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_small"
        android:text="加载失败"
        android:textAppearance="@style/Text.Title.Medium"
        android:textColor="@color/text_secondary"
        tools:text="加载失败" />

    <TextView
        android:id="@+id/tvErrorMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:text="网络连接失败，请检查网络设置"
        android:textAppearance="@style/Text.Body.Medium"
        android:textColor="@color/text_hint"
        tools:text="网络连接失败，请检查网络设置" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRetry"
        style="@style/Widget.SharedParking.Button.Outlined"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="重试"
        android:textSize="14sp" />

</LinearLayout>