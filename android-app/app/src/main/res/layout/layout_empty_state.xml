<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/spacing_large">

    <ImageView
        android:id="@+id/ivEmptyIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:src="@drawable/ic_empty_state"
        android:tint="@color/text_disabled"
        tools:src="@drawable/ic_empty_state" />

    <TextView
        android:id="@+id/tvEmptyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_small"
        android:text="暂无数据"
        android:textAppearance="@style/Text.Title.Medium"
        android:textColor="@color/text_secondary"
        tools:text="暂无数据" />

    <TextView
        android:id="@+id/tvEmptyMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="这里还没有内容"
        android:textAppearance="@style/Text.Body.Medium"
        android:textColor="@color/text_hint"
        tools:text="这里还没有内容" />

</LinearLayout>