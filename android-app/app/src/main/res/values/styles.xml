<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SharedParking" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorSecondaryVariant">@color/accent_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.SharedParking.Splash" parent="Theme.SharedParking">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.SharedParking.Button" parent="Widget.AppCompat.Button">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- CardView styles -->
    <style name="Widget.SharedParking.CardView" parent="CardView">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="cardPreventCornerOverlap">false</item>
    </style>

    <!-- Text styles -->
    <style name="Text.Title.Large">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Title.Medium">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Title.Small">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Body.Large">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Body.Medium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Text.Body.Small">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_hint</item>
    </style>

    <!-- Button outlined style -->
    <style name="Widget.SharedParking.Button.Outlined" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btn_outline</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- TextInputLayout style -->
    <style name="Widget.SharedParking.TextInputLayout" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/edittext_background</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- 兼容性样式 - 为旧布局文件添加 -->
    <style name="Text.Body" parent="Text.Body.Medium" />
    <style name="Text.Title" parent="Text.Title.Medium" />
    <style name="Text" parent="Text.Body.Medium" />

    <!-- 缺失的样式 -->
    <style name="Widget.SharedParking.ProgressBar" parent="Widget.AppCompat.ProgressBar">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:indeterminateTint">@color/brand_primary</item>
    </style>

    <style name="Text.Link">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_link</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="Widget.SharedParking.Chip.Filter" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/rounded_corner_outline</item>
        <item name="android:textColor">@color/tag_text</item>
        <item name="android:padding">8dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:minHeight">32dp</item>
    </style>

    <style name="Widget.SharedParking.TextInputLayout.Search" parent="Widget.SharedParking.TextInputLayout">
        <item name="android:hint">@string/hint_search_address_or_keyword</item>
        <item name="android:drawableStart">@drawable/ic_search</item>
        <item name="android:drawablePadding">8dp</item>
    </style>

    <style name="Text.Body.Small.Strikethrough" parent="Text.Body.Small">
        <item name="android:textStyle">normal</item>
    </style>

    <!-- 更多缺失的样式 -->
    <style name="Widget.SharedParking.TabLayout" parent="Widget.Design.TabLayout">
        <item name="tabIndicatorColor">@color/brand_primary</item>
        <item name="tabSelectedTextColor">@color/brand_primary</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabIndicatorHeight">3dp</item>
    </style>

    <style name="Widget.SharedParking.Chip.Status" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/rounded_corner</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:padding">4dp</item>
        <item name="android:textSize">10sp</item>
        <item name="android:minHeight">20dp</item>
    </style>

    <style name="Text.Caption" parent="Text.Body.Small">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_hint</item>
    </style>

    <style name="Theme.SharedParking.Dialog" parent="Theme.AppCompat.Light.Dialog">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
    </style>
</resources>