# ============================================================
# 共享停车位平台 - 生产环境配置
# 复制此文件为 .env 并修改配置:
#   cp docker/.env.example .env
# ============================================================

# ----- 应用配置 -----
APP_URL=http://your-domain.com        # 你的域名或服务器IP
APP_PORT=80                            # 对外端口
APP_ENV=production
APP_DEBUG=false

# ----- MySQL 数据库 -----
DB_ROOT_PASSWORD=your_strong_root_password
DB_DATABASE=shared_parking
DB_USERNAME=shared_parking
DB_PASSWORD=your_strong_db_password

# ----- JWT 密钥（务必修改！）-----
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# ----- 高德地图 Key -----
AMAP_KEY=a3cd510ffc1871168cbee271105ad260
